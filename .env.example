# =============================================================================
# LLM Benchmark 環境變數範本
# 複製此檔成 .env 並填入實際的值：cp .env.example .env
# =============================================================================

# LiteLLM Proxy（公司用的 LLM Gateway，或自架的 LiteLLM）
# 此網址後面要會接 /v1（程式自動加）
LITELLM_URL=https://llmgw.elandai.cloud

# LiteLLM API Key（所有模型呼叫共用）
LITELLM_API_KEY=sk-your-litellm-api-key-here

# Judge 用的 API Key（評分用，通常跟 LITELLM_API_KEY 一樣）
# 不填時自動 fallback 到 LITELLM_API_KEY
JUDGE_LITELLM_API_KEY=

# 預設 Judge 模型名稱（也可在 UI 上覆寫）
JUDGE_MODEL_NAME=gpt-4o-mini

# MCP（Model Context Protocol）用的 key，只在跑 MCP 相關功能才需要
LITELLM_MCP_API_KEY=
